    "qa:lighthouse:dev": "QA_BASE_URL=http://127.0.0.1:3000 QA_LIGHTHOUSE_RUNS=3 node .qa-lighthouse.js",
    "qa:a11y": "node .qa-a11y.js",
    "qa:a11y:p2": "QA_A11Y_VIEWPORTS=desktop,mobile,fold QA_A11Y_ROUTES=/explore,/screener,/stock/NVDA,/stock/ZZZZ,/market-valuation,/sectors node .qa-a11y.js",
    "qa:a11y:mobile": "QA_A11Y_VIEWPORTS=mobile,fold QA_A11Y_ROUTES=/,/posts,/vr,/explore,/screener,/portfolio,/stock/NVDA,/stock/ZZZZ,/superinvestors,/market-valuation,/sectors,/admin,/admin/design-lab?mode=native,/tools/stock-analyzer/native,/etfs,/etfs/new,/etfs/SPY,/etfs/ADIU node .qa-a11y.js",
