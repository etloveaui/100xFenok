    "qa:history-gap": "node scripts/report-stockanalysis-history-gap.mjs",
    "qa:edgar-summaries": "node scripts/check-edgar-summary-evidence.mjs",
    "qa:edgar-translations": "node scripts/check-edgar-translation-contract.mjs",
