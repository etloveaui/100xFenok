100xfenok-next/*lighthouse.*/
100xfenok-next/*lighthouse.*/**

# Git Artifacts
.git-rewrite/

# Large binary data (removed from history via git filter-repo)
*.xlsb

# Local Next.js build backups
100xfenok-next/.next_prev_*/

# Build-artifact mirrors regenerated by `npm run sync-static` (package.json build:runtime/predev).
# Source-of-truth lives in ../tools and ../data; these public/ copies are rebuilt every build/dev.
100xfenok-next/public/tools/stock_analyzer/data/global_scouter_integrated.json
100xfenok-next/public/data/sec-13f/investors/griffin.json

# StockAnalysis chunked backfill scratch artifacts; canonical completed JSON files stay trackable.
data/stockanalysis/backfill/*.partial.*
data/stockanalysis/backfill/*.ignored
100xfenok-next/public/data/stockanalysis/backfill/*.partial.*
100xfenok-next/public/data/stockanalysis/backfill/*.ignored

# Private local study data (Mona Wind-Down English coach) — personal, never commit
100xfenok-next/_tmp/
100xfenok-next/data/mona-english
100xfenok-next/data/voice-logs/

# Private external-source raw caches; never mirror to public assets.
_private/
data/admin/fenok-flow/
