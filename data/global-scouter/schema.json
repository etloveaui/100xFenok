{
  "folder": "global-scouter",
  "version": "2.3.0",
  "updated": "2026-07-17",
  "source": "Global Scouter Tool",
  "update_frequency": "on-demand",
  "maintainer": "Manual conversion scripts",
  "structure": {
    "core/": "Dashboard config, metadata, master stock index, and site-derived analyzer indexes",
    "stocks/detail/": "1,064 individual stock profiles",
    "etfs/": "ETF and index benchmarks",
    "indicators/": "Economic indicators",
    "raw/": "Source-sheet raw preservation layer"
  },
  "files": {
    "core/dashboard.json": {
      "description": "Dashboard configuration",
      "size_kb": 3.1,
      "schema": {
        "config": "object (UI settings)"
      }
    },
    "core/metadata.json": {
      "description": "System metadata",
      "size_kb": 0.4,
      "source_date": "2026-07-17",
      "schema": {
        "version": "string",
        "last_updated": "ISO timestamp"
      }
    },
    "core/stocks_index.json": {
      "description": "Master stock index (ticker -> basic info)",
      "size_kb": 280.4,
      "stock_count": 1064,
      "schema": {
        "stocks.{TICKER}": {
          "n": "string (name)",
          "x": "string (exchange)",
          "s": "string (sector)",
          "c": "string (country)",
          "p": "number (price)",
          "mc": "number (market_cap)",
          "pe": "number (PER forward)",
          "pb": "number (PBR forward)",
          "dy": "number (dividend yield)",
          "r12": "number (12M return)"
        }
      }
    },
    "stocks/detail/{TICKER}.json": {
      "description": "Individual stock profile (1,064 files)",
      "schema": {
        "years": "string[] (FY-4 to FY0)",
        "raw_periods": "string[] (FY-4 to FY+3) - v2.3.0",
        "scale": {
          "market_cap": "number[]",
          "stock_price": "number[]",
          "total_assets": "number[]",
          "total_equity": "number[]"
        },
        "income_statement": {
          "revenue": "number[]",
          "gross_profit": "number[]",
          "operating_income": "number[]",
          "net_income": "number[]"
        },
        "cash_flow": {
          "cfo": "number[]",
          "capex": "number[]",
          "fcf": "number[]"
        },
        "profitability": {
          "gross_margin": "number[]",
          "operating_margin": "number[]",
          "roe": "number[]",
          "roa": "number[]"
        },
        "valuation": {
          "per": "number[]",
          "pbr": "number[]",
          "peg": "number[]"
        },
        "estimates": {
          "eps": {
            "fy1": "number",
            "fy2": "number",
            "fy3": "number"
          },
          "fcf": {
            "fy1": "number",
            "fy2": "number",
            "fy3": "number"
          },
          "revenue": {
            "fy1": "number",
            "fy2": "number",
            "fy3": "number"
          }
        },
        "fiscal_month": "string (Jan, Dec, etc.) - v2.2.0",
        "eps_consensus": {
          "fy_plus_1": "number",
          "fy_plus_2": "number",
          "fy_plus_3": "number",
          "_coverage": "100% (1,064 stocks) - v2.2.0"
        },
        "growth_consensus": {
          "revenue_7y": "number (%)",
          "revenue_3y": "number (%)",
          "earnings_7y": "number (%)",
          "earnings_3y": "number (%)",
          "_coverage": "100% (1,064 stocks) - v2.2.0"
        },
        "per_bands": {
          "current": "number",
          "min_8y": "number",
          "avg_8y": "number",
          "max_8y": "number",
          "source": "string (S_Valuation|calculated)",
          "per": "object (PER bands + FY-4..FY+3 raw values) - v2.3.0",
          "pbr": "object (PBR bands + FY-4..FY+3 raw values) - v2.3.0",
          "_coverage": "98.2% (1,045 stocks; direct S_Valuation or calculated/fallback) - v2.3.0"
        },
        "profitability_estimates": "object (FY+1..FY+3 margins/ROE/ROA) - v2.3.0",
        "per_share_estimates": "object (FY+1..FY+3 EPS/BPS/CPS/SPS) - v2.3.0",
        "valuation_estimates": "object (FY+1..FY+3 PER/PBR/PCR/PSR/PEG) - v2.3.0",
        "weekly_revision_history": "object (per-share forward revision, weekly consensus revision, price history) - v2.3.0",
        "raw_financials": "object (all mapped rows across FY-4..FY+3) - v2.3.0"
      }
    },
    "etfs/index.json": {
      "added_in": "2.1.0",
      "description": "22 ETFs/Indices with returns, CAGR, market cap",
      "size_kb": 13,
      "etf_count": 22,
      "schema": {
        "count": "number",
        "etfs.{name}": {
          "ticker": "string",
          "category": "string (Indices/ETF)",
          "market_cap": "number",
          "returns": {
            "1m": "number",
            "3m": "number",
            "ytd": "number",
            "1y": "number"
          },
          "cagr": {
            "3y": "number",
            "5y": "number",
            "10y": "number"
          }
        }
      }
    },
    "indicators/economic.json": {
      "added_in": "2.1.0",
      "description": "Treasury rates, spreads, HY yields, TIPS",
      "record_count": 1068,
      "schema": {
        "records[]": {
          "date": "YYYY-MM-DD",
          "t10y": "number",
          "t2y": "number",
          "t10y_2y_spread": "number",
          "hys_us": "number",
          "bei_10y": "number",
          "tips_10y": "number"
        }
      }
    },
    "raw/manifest.json": {
      "added_in": "2.3.0",
      "description": "Raw preservation manifest for source-sheet tables",
      "raw_file_count": 8,
      "public_json_files": 9,
      "sheets": [
        "A_Company",
        "M_Company",
        "S_Valuation",
        "T_EPS C",
        "T_Growth C",
        "M_ETFs",
        "A_ETFs",
        "workbook inventory"
      ],
      "schema": {
        "files": "object (raw path -> size/count/sheet)",
        "count": "number"
      }
    }
  },
  "breaking_changes_history": [
    {
      "version": "2.3.0",
      "date": "2026-05-24",
      "change": "Backward-compatible raw preservation layer and forward/revision detail extensions"
    },
    {
      "version": "2.2.0",
      "date": "2026-01-25",
      "change": "Extended fields: fiscal_month, eps_consensus, growth_consensus, per_bands"
    },
    {
      "version": "2.1.0",
      "date": "2026-01-10",
      "change": "etfs/ and indicators/ folders added"
    },
    {
      "version": "2.0.0",
      "date": "2025-12-15",
      "change": "stocks/detail/ restructured"
    },
    {
      "version": "1.0.0",
      "date": "2025-11-01",
      "change": "Initial schema"
    }
  ]
}
